<UserControl x:Class="Pcsx5Ui.ControllerVisualizer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="400" Height="500">
    <Grid Background="#282838">
        <Grid.Resources>
            <!-- Default off color for unpressed buttons -->
            <Color x:Key="OffColor">#282838</Color>
        </Grid.Resources>

        <!-- Controller body outline -->
        <Rectangle RadiusX="24" RadiusY="24" Fill="#1E1E2E" Stroke="#404060" StrokeThickness="2"/>

        <!-- === SHOULDER BUTTONS === -->
        <!-- L2 -->
        <Border x:Name="L2Border" Width="48" Height="16" CornerRadius="4" Background="#303050" BorderBrush="#404060" BorderThickness="1"
                HorizontalAlignment="Left" Margin="40,28,0,0">
            <TextBlock Text="L2" FontSize="9" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <Rectangle x:Name="L2Bar" Width="0" Height="12" RadiusX="3" RadiusY="3" Fill="#FF6633"
                   HorizontalAlignment="Left" Margin="41,30,0,0" MaxWidth="46" VerticalAlignment="Top"/>

        <!-- R2 -->
        <Border x:Name="R2Border" Width="48" Height="16" CornerRadius="4" Background="#303050" BorderBrush="#404060" BorderThickness="1"
                HorizontalAlignment="Right" Margin="0,28,40,0">
            <TextBlock Text="R2" FontSize="9" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <Rectangle x:Name="R2Bar" Width="0" Height="12" RadiusX="3" RadiusY="3" Fill="#FF6633"
                   HorizontalAlignment="Right" Margin="0,30,41,0" MaxWidth="46" VerticalAlignment="Top"/>

        <!-- L1 -->
        <Border x:Name="L1Border" Width="48" Height="16" CornerRadius="4" Background="#303050" BorderBrush="#404060" BorderThickness="1"
                HorizontalAlignment="Left" Margin="40,52,0,0">
            <TextBlock Text="L1" FontSize="9" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <!-- R1 -->
        <Border x:Name="R1Border" Width="48" Height="16" CornerRadius="4" Background="#303050" BorderBrush="#404060" BorderThickness="1"
                HorizontalAlignment="Right" Margin="0,52,40,0">
            <TextBlock Text="R1" FontSize="9" Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- === D-PAD === -->
        <Grid HorizontalAlignment="Left" Margin="60,150,0,0" Width="80" Height="80">
            <!-- Vertical bar -->
            <Rectangle x:Name="UpRect" Width="24" Height="70" RadiusX="4" RadiusY="4" Fill="#202038" HorizontalAlignment="Center"/>
            <!-- Horizontal bar -->
            <Rectangle x:Name="LeftRect" Width="70" Height="24" RadiusX="4" RadiusY="4" Fill="#202038" VerticalAlignment="Center"/>
            <!-- D-pad labels -->
            <TextBlock Text="▲" FontSize="10" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0"/>
            <TextBlock Text="▼" FontSize="10" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            <TextBlock Text="◄" FontSize="10" Foreground="#666" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"/>
            <TextBlock Text="►" FontSize="10" Foreground="#666" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"/>
        </Grid>
        <Rectangle x:Name="UpRect2" Width="24" Height="70" RadiusX="4" RadiusY="4" Fill="Transparent"
                   HorizontalAlignment="Left" Margin="60,150,0,0" IsHitTestVisible="False"/>
        <Rectangle x:Name="DownRect2" Width="24" Height="70" RadiusX="4" RadiusY="4" Fill="Transparent"
                   HorizontalAlignment="Left" Margin="60,150,0,0" IsHitTestVisible="False"/>
        <Rectangle x:Name="LeftRect2" Width="70" Height="24" RadiusX="4" RadiusY="4" Fill="Transparent"
                   HorizontalAlignment="Left" Margin="60,150,0,0" IsHitTestVisible="False"/>
        <Rectangle x:Name="RightRect2" Width="70" Height="24" RadiusX="4" RadiusY="4" Fill="Transparent"
                   HorizontalAlignment="Left" Margin="60,150,0,0" IsHitTestVisible="False"/>

        <!-- === LEFT STICK === -->
        <Grid x:Name="LeftStickArea" HorizontalAlignment="Left" Margin="70,260,0,0" Width="60" Height="60">
            <Ellipse Width="60" Height="60" Fill="#252540" Stroke="#353560" StrokeThickness="2"/>
            <Ellipse x:Name="LeftStickKnob" Width="22" Height="22" Fill="#555580" Stroke="#65A5D9" StrokeThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="L3" FontSize="8" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-12"/>
        </Grid>

        <!-- === FACE BUTTONS === -->
        <Grid HorizontalAlignment="Right" Margin="0,148,45,0" Width="90" Height="90">
            <!-- Triangle -->
            <Ellipse x:Name="TriangleBtn" Width="22" Height="22" Fill="#202038" Stroke="#30CC4488" StrokeThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
            <TextBlock Text="▲" FontSize="11" Foreground="#30CC44" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0"/>
            <!-- Circle -->
            <Ellipse x:Name="CircleBtn" Width="22" Height="22" Fill="#202038" Stroke="#FF883388" StrokeThickness="1"
                     HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Text="●" FontSize="10" Foreground="#FF8833" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"/>
            <!-- Cross -->
            <Ellipse x:Name="CrossBtn" Width="22" Height="22" Fill="#202038" Stroke="#3399FF88" StrokeThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
            <TextBlock Text="✕" FontSize="10" Foreground="#3399FF" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
            <!-- Square -->
            <Ellipse x:Name="SquareBtn" Width="22" Height="22" Fill="#202038" Stroke="#FF77AA88" StrokeThickness="1"
                     HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0,0,0"/>
            <TextBlock Text="□" FontSize="11" Foreground="#FF77AA" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="7,0,0,0"/>
        </Grid>

        <!-- === RIGHT STICK === -->
        <Grid x:Name="RightStickArea" HorizontalAlignment="Right" Margin="0,260,55,0" Width="60" Height="60">
            <Ellipse Width="60" Height="60" Fill="#252540" Stroke="#353560" StrokeThickness="2"/>
            <Ellipse x:Name="RightStickKnob" Width="22" Height="22" Fill="#555580" Stroke="#65A5D9" StrokeThickness="1"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Text="R3" FontSize="8" Foreground="#666" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-12"/>
        </Grid>

        <!-- === TOUCHPAD === -->
        <Canvas HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,375,0,0" Width="180" Height="44">
            <Rectangle Width="180" Height="44" RadiusX="4" RadiusY="4" Fill="#181828" Stroke="#404060" StrokeThickness="1"
                       Canvas.Left="0" Canvas.Top="0"/>
            <TextBlock Text="Touch Pad" FontSize="9" Foreground="#555" Canvas.Left="60" Canvas.Top="14"/>
            <!-- Touch fingers -->
            <Ellipse x:Name="TouchFinger1" Width="8" Height="8" Fill="#FFCC33" Visibility="Hidden"/>
            <Ellipse x:Name="TouchFinger2" Width="8" Height="8" Fill="#FFCC33" Visibility="Hidden"/>
        </Canvas>

        <!-- === CENTER BUTTONS === -->
        <Ellipse x:Name="PsBtn" Width="20" Height="20" Fill="#252540" Stroke="#505070" StrokeThickness="1"
                 HorizontalAlignment="Center" Margin="0,325,0,0"/>
        <Ellipse x:Name="CreateBtn" Width="10" Height="10" Fill="#252540" Stroke="#505070" StrokeThickness="1"
                 HorizontalAlignment="Left" Margin="120,330,0,0"/>
        <Ellipse x:Name="OptionsBtn" Width="10" Height="10" Fill="#252540" Stroke="#505070" StrokeThickness="1"
                 HorizontalAlignment="Right" Margin="0,330,120,0"/>
        <Ellipse x:Name="MuteBtn" Width="10" Height="10" Fill="#252540" Stroke="#505070" StrokeThickness="1"
                 HorizontalAlignment="Left" Margin="55,320,0,0"/>
        <TextBlock Text="PS" FontSize="5" Foreground="#666" HorizontalAlignment="Center" Margin="0,348,0,0"/>

        <!-- === STATUS === -->
        <TextBlock x:Name="StatusText" Text="Disconnected" FontSize="9" Foreground="#FF5555"
                   HorizontalAlignment="Center" Margin="0,435,0,0"/>
        <TextBlock x:Name="BatteryText" Text="" FontSize="8" Foreground="#888"
                   HorizontalAlignment="Center" Margin="0,450,0,0"/>
    </Grid>
</UserControl>
