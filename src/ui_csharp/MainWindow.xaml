<Window x:Class="Pcsx5Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCSX5 - PlayStation 5 Emulator" Height="780" Width="1200"
        MinWidth="1050" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#0A0D14"
        Foreground="White"
        FontFamily="Segoe UI Semibold, Inter, Outfit, Arial"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" 
                      CornerRadius="12" 
                      CaptionHeight="50" 
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Modern Windows 11 style global resources -->
        <SolidColorBrush x:Key="SystemAccentBrush" Color="#0099FF"/>
        <SolidColorBrush x:Key="AccentGlowBrush" Color="#3F0099FF"/>
        <SolidColorBrush x:Key="GlassBackgroundBrush" Color="#CC0A0D14"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#3F000000"/>
        
        <!-- Navigation tab button style -->
        <Style x:Key="NavTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFA0A0A5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="20,0,20,0"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1EFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8,15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3DFFFFFF"/>
                    <Setter Property="BorderBrush" Value="#4FFFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F242F"/>
            <Setter Property="Foreground" Value="#FFA0A0A5"/>
            <Setter Property="BorderBrush" Value="#2A2F3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,5,15,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2F3D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Immersive Full Window Background Image with opacity -->
        <Image x:Name="WindowBgImage" Stretch="UniformToFill" Opacity="0.28" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image.Effect>
                <BlurEffect Radius="15" KernelType="Gaussian"/>
            </Image.Effect>
        </Image>
        
        <!-- Dark gradient overlay to fade the background art to black at the edges -->
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Color="#8F0A0D14" Offset="0.0"/>
                        <GradientStop Color="#BF0A0D14" Offset="0.6"/>
                        <GradientStop Color="#FD05060A" Offset="1.0"/>
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Main Window Layout -->
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <!-- Title Bar & Navigation -->
                <RowDefinition Height="65"/>
                <!-- Content Area -->
                <RowDefinition Height="*"/>
                <!-- Status/Footer Bar -->
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Title Bar & Navigation Grid -->
            <Border Grid.Row="0" Background="#4F05060A" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="PCSX5" Foreground="#0099FF" FontSize="20" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                        <TextBlock Text="PS5" Foreground="#A0A0A5" FontSize="11" Margin="8,4,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation Tabs -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="TabLibraryBtn" Content="GAME LIBRARY" Style="{StaticResource NavTabButtonStyle}" Click="TabLibrary_Click"/>
                        <Button x:Name="TabAnalyzerBtn" Content="BOOT ANALYZER" Style="{StaticResource NavTabButtonStyle}" Click="TabAnalyzer_Click"/>
                        <Button x:Name="TabControllerBtn" Content="CONTROLLER SETUP" Style="{StaticResource NavTabButtonStyle}" Click="TabController_Click"/>
                        <Button x:Name="TabSettingsBtn" Content="SYSTEM SETTINGS" Style="{StaticResource NavTabButtonStyle}" Click="TabSettings_Click"/>
                        <Button x:Name="TabLogsBtn" Content="CONSOLE LOGS" Style="{StaticResource NavTabButtonStyle}" Click="TabLogs_Click"/>
                    </StackPanel>

                    <!-- Top-Right Controls & Search Box -->
                    <Grid Grid.Column="2" VerticalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button x:Name="BtnMinimize" Content="⚊" Width="42" Height="26" Background="Transparent" Foreground="#D0FFFFFF" BorderThickness="0" FontSize="11" Click="Minimize_Click" Style="{x:Null}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnMaximize" Content="🗖" Width="42" Height="26" Background="Transparent" Foreground="#D0FFFFFF" BorderThickness="0" FontSize="10" Click="Maximize_Click" Style="{x:Null}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnClose" Content="✕" Width="42" Height="26" Background="Transparent" Foreground="#D0FFFFFF" BorderThickness="0" FontSize="11" Click="Close_Click" Style="{x:Null}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <!-- Search box below controls -->
                        <Grid Width="200" Height="30" Margin="0,0,25,6" HorizontalAlignment="Right" VerticalAlignment="Bottom" WindowChrome.IsHitTestVisibleInChrome="True">
                            <!-- Background Pill -->
                            <Border x:Name="SearchBoxBorder" CornerRadius="15" Background="#2FFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Search Icon -->
                                    <TextBlock Grid.Column="0" Text="🔍" Foreground="#FFA0A0A5" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <!-- TextBox -->
                                    <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" Foreground="White" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="0,0,10,0" FontSize="11" FontWeight="SemiBold" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus" TextChanged="SearchBox_TextChanged"/>
                                    <!-- Placeholder Text -->
                                    <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="Search Games..." Foreground="#6FA0A0A5" FontSize="11" VerticalAlignment="Center" Padding="0,0,10,0" IsHitTestVisible="False" Visibility="Visible"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- CONTENT VIEWS -->
            <Grid Grid.Row="1">
                
                <!-- 1. GAME LIBRARY VIEW (GRID) -->
                <Grid x:Name="LibraryView" Visibility="Visible" Margin="0">
                    <Grid.RowDefinitions>
                        <!-- Upper details area -->
                        <RowDefinition Height="*"/>
                        <!-- Lower carousel shelf -->
                        <RowDefinition Height="265"/>
                    </Grid.RowDefinitions>

                    <!-- Upper details area: details about selected game -->
                    <Grid Grid.Row="0" Margin="40,25,40,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/> <!-- Text Details -->
                            <ColumnDefinition Width="1*"/>   <!-- Mini Cover Display -->
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Big Game Title & Play Controls -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <!-- Game Title -->
                            <TextBlock x:Name="DetailTitle" Text="Select a Game" FontSize="42" FontWeight="ExtraBold" Foreground="White" TextWrapping="Wrap" LineHeight="48"/>
                            
                            <!-- Metadata badges & ID -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                                <TextBlock x:Name="DetailTitleId" Text="No game selected" FontSize="13" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                                <TextBlock Text="•" Foreground="#FFA0A0A5" Margin="10,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DetailSize" Text="-" FontSize="13" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                                <TextBlock Text="•" Foreground="#FFA0A0A5" Margin="10,0,10,0" VerticalAlignment="Center"/>
                                
                                <Border x:Name="DetailCompatBadge" Padding="8,3,8,3" CornerRadius="4" Background="#3F555555" VerticalAlignment="Center">
                                    <TextBlock x:Name="DetailCompatText" Text="UNKNOWN" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <!-- Path info -->
                            <TextBlock Text="Executable Path:" FontSize="11" Foreground="#6FA0A0A5" Margin="0,0,0,3"/>
                            <TextBlock x:Name="DetailPath" Text="-" FontSize="11" Foreground="#FFA0A0A5" TextWrapping="Wrap" MaxHeight="45" Margin="0,0,0,25"/>

                            <!-- Play/Launch Button -->
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="LaunchButton" Content="Play Game" Width="200" Height="48" FontSize="15" FontWeight="Bold" Cursor="Hand" Click="LaunchButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="24" BorderBrush="#3FFFFFFF" BorderThickness="1">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="#0078D4" BlurRadius="15" Opacity="0.5" ShadowDepth="0"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0099FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button x:Name="StopButton" Content="Stop" Width="100" Height="48" FontSize="15" FontWeight="Bold" Margin="15,0,0,0" Cursor="Hand" Visibility="Collapsed" Click="StopButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#CC2200"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="24" BorderBrush="#3FFFFFFF" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF3300"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: Visual Art Preview of Selected Game -->
                        <Border x:Name="GameCoverDisplayBorder" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Width="220" Height="220" CornerRadius="12" BorderBrush="#2FFFFFFF" BorderThickness="1" Background="#1F000000"/>
                    </Grid>

                    <!-- Lower Carousel shelf: horizontal scrolling game icons -->
                    <Grid Grid.Row="1" Background="#2F05060A">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock x:Name="LibraryHeaderTextBlock" Grid.Row="0" Text="Game Library" FontSize="13" FontWeight="Bold" Foreground="#FFA0A0A5" Margin="40,15,40,5"/>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Style="{StaticResource ModernScrollViewer}" Padding="35,0,35,0">
                            <StackPanel x:Name="GamesWrapPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="200"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                
                <!-- 1.5. BOOT ANALYZER VIEW (GRID) -->
                <Grid x:Name="AnalyzerView" Visibility="Collapsed" Margin="40,20,40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Top Buttons -->
                        <RowDefinition Height="*"/>    <!-- Main Split Area -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="AnalyzerHeaderTextBlock" Text="Executable Boot &amp; Memory Analyzer" FontSize="14" FontWeight="Bold" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Analyze All Games" Style="{StaticResource ModernButtonStyle}" Click="AnalyzeAll_Click"/>
                            <Button Content="Export Minimal Summary" Style="{StaticResource ModernButtonStyle}" Margin="10,0,0,0" Click="ExportSummary_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.8*"/> <!-- Left: ListView -->
                            <ColumnDefinition Width="1.2*"/> <!-- Right: Selected Game Details / Log -->
                        </Grid.ColumnDefinitions>

                        <!-- ListView -->
                        <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                            <ListView x:Name="AnalyzerListView" Background="Transparent" Foreground="White" BorderThickness="0" SelectionChanged="AnalyzerListView_SelectionChanged">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Game Title" Width="180" DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="Title ID" Width="80" DisplayMemberBinding="{Binding TitleId}"/>
                                        <GridViewColumn Header="Format" Width="90" DisplayMemberBinding="{Binding Format}"/>
                                        <GridViewColumn Header="Encryption" Width="100" DisplayMemberBinding="{Binding EncryptionStatus}"/>
                                        <GridViewColumn Header="Footprint" Width="80" DisplayMemberBinding="{Binding MemoryFootprint}"/>
                                        <GridViewColumn Header="Alignment" Width="80" DisplayMemberBinding="{Binding AlignmentStatus}"/>
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Margin" Value="0,2,0,2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3F0099FF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#20FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Border>

                        <!-- Raw Log View on the Right -->
                        <Border Grid.Column="1" Background="#E0050508" BorderBrush="#1EFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Detailed Parser Analysis Log" FontSize="11" Foreground="#FFA0A0A5" Margin="0,0,0,8"/>
                                <TextBox x:Name="AnalyzerOutputTextBox" Grid.Row="1" Background="Transparent" Foreground="#FFCC66" FontFamily="Consolas, Courier New" FontSize="10.5" 
                                         BorderThickness="0" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" AcceptsReturn="True"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                
                <!-- 1.7. CONTROLLER SETUP VIEW (GRID) -->
                <Grid x:Name="ControllerView" Visibility="Collapsed" Margin="40,10,40,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Controller Setup" FontSize="14" FontWeight="Bold" Foreground="#FFA0A0A5" Margin="0,0,0,5"/>

                    <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Left side mapping (D-Pad, L1/L2, Left Stick, Deadzone) -->
                                <ColumnDefinition Width="260"/>
                                <!-- Center side (Config Selection, DualSense Image, Touchpad, Color, Save buttons) -->
                                <ColumnDefinition Width="*"/>
                                <!-- Right side mapping (Face buttons, R1/R2, Right Stick, Deadzone) -->
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <!-- COLUMN 0: LEFT SIDE MAPPINGS -->
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,10,0">
                                    <!-- D-PAD CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="D-Pad" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Up" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="pad_up" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Left" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="pad_left" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Right" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="pad_right" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Down" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="pad_down" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- L1 and L2 CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="L1 and L2" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="L1" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="l1" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="L2" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="l2" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- LEFT STICK DEADZONE CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Left Stick Deadzone" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <TextBlock Text="Min Deadzone (def: 2 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMinDeadzoneLSlider" Minimum="0" Maximum="127" Value="2" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMinDeadzoneLSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Max Deadzone (def: 127 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMaxDeadzoneLSlider" Minimum="0" Maximum="127" Value="127" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMaxDeadzoneLSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- LEFT STICK CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Left Stick" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Up" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_left_y" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Left" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_left_x" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Right" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_left_x" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Down" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_left_y" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- COLUMN 1: CENTER AREA -->
                            <Grid Grid.Column="1" Margin="10,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Config selection -->
                                    <RowDefinition Height="*"/>    <!-- PS5 image -->
                                    <RowDefinition Height="Auto"/> <!-- Bottom buttons (L3, Options, R3, etc.) -->
                                    <RowDefinition Height="Auto"/> <!-- Color adjustment -->
                                    <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                                </Grid.RowDefinitions>

                                <!-- Config Selection Card -->
                                <Border Grid.Row="0" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Text="Config Selection" FontSize="11" FontWeight="Bold" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <ComboBox x:Name="CtrlConfigCombo" SelectedIndex="0" Width="140" Height="24" Background="#2FFFFFFF" Foreground="Black">
                                                <ComboBoxItem Content="Common Config"/>
                                            </ComboBox>
                                            <CheckBox x:Name="CtrlUsePerGameConfigCheck" Content="Use per-game configs" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                            <TextBlock Text="Active Gamepad:" Foreground="#FFA0A0A5" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>
                                            <ComboBox x:Name="CtrlActiveGamepadCombo" SelectedIndex="0" Width="160" Height="24" Background="#2FFFFFFF" Foreground="Black">
                                                <ComboBoxItem Content="DualSense Wireless Controller (Auto-Detected)"/>
                                                <ComboBoxItem Content="Xbox Controller (XInput)"/>
                                            </ComboBox>
                                            <Button Content="Set Active Gamepad as Default" Style="{StaticResource ModernButtonStyle}" Height="24" FontSize="10" Padding="8,0,8,0" Margin="10,0,0,0" Click="SaveSettingsBtn_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Controller Image -->
                                <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image Source="ps5_controller.png" Stretch="Uniform" Height="220" Opacity="0.85"/>
                                </Grid>

                                <!-- Bottom buttons (L3, Options, R3, Touchpad) -->
                                <Border Grid.Row="2" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="2,0,2,0">
                                            <TextBlock Text="L3" FontSize="10" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button Content="l3" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="2,0,2,0">
                                            <TextBlock Text="Options" FontSize="10" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button Content="options" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Grid.Row="0" Margin="2,0,2,0">
                                            <TextBlock Text="R3" FontSize="10" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button Content="r3" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="2,5,2,0">
                                            <TextBlock Text="Touchpad Left" FontSize="10" Foreground="#FFA0A0A5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button Content="unmapped" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="2,5,2,0">
                                            <TextBlock Text="Touchpad Center" FontSize="10" Foreground="#FFA0A0A5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button Content="back" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Grid.Row="1" Margin="2,5,2,0">
                                            <TextBlock Text="Touchpad Right" FontSize="10" Foreground="#FFA0A0A5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button Content="unmapped" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Color Adjustment & Rumble Card -->
                                <Border Grid.Row="3" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Color Adjustment" FontSize="10" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,4"/>
                                            
                                            <!-- RED -->
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="RED" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                                                <Slider x:Name="CtrlColorRSlider" Minimum="0" Maximum="255" Value="0" TickFrequency="16" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center" ValueChanged="CtrlColorSliders_ValueChanged"/>
                                            </Grid>
                                            
                                            <!-- GREEN -->
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="GREEN" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                                                <Slider x:Name="CtrlColorGSlider" Minimum="0" Maximum="255" Value="0" TickFrequency="16" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center" ValueChanged="CtrlColorSliders_ValueChanged"/>
                                            </Grid>
                                            
                                            <!-- BLUE -->
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="BLUE" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                                                <Slider x:Name="CtrlColorBSlider" Minimum="0" Maximum="255" Value="255" TickFrequency="16" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center" ValueChanged="CtrlColorSliders_ValueChanged"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <CheckBox x:Name="CtrlOverrideColorCheck" Content="Override Color" Foreground="White" FontSize="10" IsChecked="True" Margin="0,0,0,6"/>
                                            <Border Background="Blue" Height="30" BorderBrush="White" BorderThickness="1" CornerRadius="4" x:Name="CtrlColorBox"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Bottom actions -->
                                <Grid Grid.Row="4" Margin="0,5,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Content="Restore Defaults" Style="{StaticResource ModernButtonStyle}" Width="110" Height="26" FontSize="10" Padding="0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Save" Style="{StaticResource ModernButtonStyle}" Width="65" Height="26" FontSize="10" Padding="0" Click="SaveSettingsBtn_Click"/>
                                        <Button Content="Cancel" Style="{StaticResource ModernButtonStyle}" Width="65" Height="26" FontSize="10" Padding="0" Margin="6,0,0,0"/>
                                        <Button Content="Apply" Style="{StaticResource ModernButtonStyle}" Width="65" Height="26" FontSize="10" Padding="0" Margin="6,0,0,0" Click="SaveSettingsBtn_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>

                            <!-- COLUMN 2: RIGHT SIDE MAPPINGS -->
                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="10,0,0,0">
                                    <!-- FACE BUTTONS CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Face Buttons" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Triangle" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="triangle" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Circle" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="circle" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Cross" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="cross" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Square" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="square" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- R1 and R2 CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="R1 and R2" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="R1" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="r1" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="R2" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="r2" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- RIGHT STICK DEADZONE CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Right Stick Deadzone" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <TextBlock Text="Min Deadzone (def: 2 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMinDeadzoneRSlider" Minimum="0" Maximum="127" Value="2" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMinDeadzoneRSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Max Deadzone (def: 127 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMaxDeadzoneRSlider" Minimum="0" Maximum="127" Value="127" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMaxDeadzoneRSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- RIGHT STICK CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Right Stick" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Up" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_right_y" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Left" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_right_x" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Right" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_right_x" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Down" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button Content="axis_right_y" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- 2. SYSTEM SETTINGS VIEW (GRID) -->
                <Grid x:Name="SettingsView" Visibility="Collapsed" Margin="40,20,40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,15,0">
                            
                            <!-- GAME DIRECTORIES CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="GAME DIRECTORIES" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Folder ListBox -->
                                        <ListBox x:Name="GameFoldersListBox" Grid.Row="0" Background="#20FFFFFF" Foreground="White" BorderBrush="#15FFFFFF" BorderThickness="1">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="5"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                        
                                        <!-- Actions -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button x:Name="BtnAddFolder" Content="Add Folder" Style="{StaticResource ModernButtonStyle}" Width="110" Click="BtnAddFolder_Click"/>
                                            <Button x:Name="BtnRemoveFolder" Content="Remove Selected" Style="{StaticResource ModernButtonStyle}" Width="140" Margin="10,0,0,0" Click="BtnRemoveFolder_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- GRAPHICS CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="GRAPHICS SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Renderer -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Renderer API" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="GpuRendererCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="Vulkan"/>
                                            <ComboBoxItem Content="OpenGL (Experimental)"/>
                                        </ComboBox>

                                        <!-- Fullscreen -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Start in Fullscreen" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="GpuFullscreenCheck" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Resolution Scale -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Resolution Scale" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="GpuResScaleSlider" Width="150" Minimum="0.5" Maximum="2.0" TickFrequency="0.25" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="GpuResScaleSlider_ValueChanged"/>
                                            <TextBlock x:Name="GpuResScaleText" Text="1.0x" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Custom Window Dimensions -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Default Window Size (W x H)" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBox x:Name="GpuWidthText" Width="60" Height="24" Background="#20FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#15FFFFFF" VerticalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Text="x" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                            <TextBox x:Name="GpuHeightText" Width="60" Height="24" Background="#20FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#15FFFFFF" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- AUDIO CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="AUDIO SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Audio Backend -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Audio Output Backend" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="SndBackendCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="Null Driver (No Audio)"/>
                                            <ComboBoxItem Content="WASAPI"/>
                                            <ComboBoxItem Content="XAudio2"/>
                                        </ComboBox>

                                        <!-- Audio Volume -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Volume" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="SndVolumeSlider" Width="150" Minimum="0" Maximum="1" TickFrequency="0.1" VerticalAlignment="Center" ValueChanged="SndVolumeSlider_ValueChanged"/>
                                            <TextBlock x:Name="SndVolumeText" Text="100%" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Audio Buffer -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Audio Buffer Latency" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="SndBufferSlider" Width="150" Minimum="10" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SndBufferSlider_ValueChanged"/>
                                            <TextBlock x:Name="SndBufferText" Text="50 ms" Width="50" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Title Music Preview -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Enable Title Screen Background Music" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="SndTitleMusicCheck" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SndTitleMusicCheck_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- INPUT CONTROLLER CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="INPUT SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Input Backend -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Gamepad Input Backend" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="InBackendCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="SDL Controller"/>
                                            <ComboBoxItem Content="XInput Controller"/>
                                        </ComboBox>

                                        <!-- Deadzone -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Analog Stick Deadzone" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="InDeadzoneSlider" Width="150" Minimum="0" Maximum="0.5" TickFrequency="0.05" VerticalAlignment="Center" ValueChanged="InDeadzoneSlider_ValueChanged"/>
                                            <TextBlock x:Name="InDeadzoneText" Text="15%" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Rumble -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Enable Controller Rumble" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="InRumbleCheck" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- HLE & COMPILER CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="SYSTEM &amp; EMULATION SETTINGS (HLE)" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Strict Imports -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Strict Symbol Imports Verification" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="HleStrictCheck" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Trace Calls -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Trace Function Calls" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="HleTraceCheck" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Trace Capacity -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Trace Ring Buffer Capacity" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="HleTraceCapSlider" Width="150" Minimum="64" Maximum="1024" TickFrequency="64" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="HleTraceCapSlider_ValueChanged"/>
                                            <TextBlock x:Name="HleTraceCapText" Text="256" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Write Minidump -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Write Crash Minidump" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="HleWriteDumpCheck" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- LOGGING CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="LOGGING SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Log level -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Minimum Log Verbosity Level" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="LogMinLevelCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="Trace"/>
                                            <ComboBoxItem Content="Debug"/>
                                            <ComboBoxItem Content="Info"/>
                                            <ComboBoxItem Content="Warning"/>
                                            <ComboBoxItem Content="Error"/>
                                            <ComboBoxItem Content="Fatal"/>
                                        </ComboBox>

                                        <!-- Append log file -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Append to Existing Log File" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="LogFileAppendCheck" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- JSON Output -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Format Log Output as JSON" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="LogJsonCheck" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- UI SETTINGS CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="UI &amp; LOCALIZATION" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Interface Language" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="UiLanguageCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="English (United States)" Tag="en-US"/>
                                            <ComboBoxItem Content="Deutsch (Deutschland)" Tag="de-DE"/>
                                            <ComboBoxItem Content="Español (España)" Tag="es-ES"/>
                                            <ComboBoxItem Content="Français (France)" Tag="fr-FR"/>
                                            <ComboBoxItem Content="Italiano (Italia)" Tag="it-IT"/>
                                            <ComboBoxItem Content="日本語 (日本)" Tag="ja-JP"/>
                                            <ComboBoxItem Content="한국어 (대한민국)" Tag="ko-KR"/>
                                            <ComboBoxItem Content="Português (Brasil)" Tag="pt-BR"/>
                                            <ComboBoxItem Content="Русский (Россия)" Tag="ru-RU"/>
                                            <ComboBoxItem Content="简体中文 (中国)" Tag="zh-CN"/>
                                            <ComboBoxItem Content="繁體中文 (台灣)" Tag="zh-TW"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <Button x:Name="SaveSettingsBtn" Grid.Row="1" Content="Save Configuration" Width="180" Height="36" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Right" Margin="0,10,15,0" Click="SaveSettingsBtn_Click"/>
                </Grid>

                <!-- 3. CONSOLE LOGS VIEW (GRID) -->
                <Grid x:Name="LogsView" Visibility="Collapsed" Margin="40,20,40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="LogsHeaderTextBlock" Text="Emulator Console Output Log" FontSize="14" FontWeight="Bold" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Copy Output" Style="{StaticResource ModernButtonStyle}" Click="CopyConsole_Click"/>
                            <Button Content="Clear Logs" Style="{StaticResource ModernButtonStyle}" Margin="10,0,0,0" Click="ClearConsole_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#E0050508" BorderBrush="#1EFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                        <RichTextBox x:Name="ConsoleOutputRichBox" Background="Transparent" FontFamily="Consolas, Courier New" FontSize="11"
                                     BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled" Foreground="#FFCC66"
                                     IsDocumentEnabled="True" AcceptsReturn="True">
                            <RichTextBox.Resources>
                                <Style TargetType="Paragraph">
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </RichTextBox.Resources>
                            <FlowDocument x:Name="ConsoleDoc" PageWidth="3000"/>
                        </RichTextBox>
                    </Border>
                </Grid>

            </Grid>

            <!-- FOOTER STATUS BAR -->
            <Border Grid.Row="2" Background="#A0050508" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                        <TextBlock x:Name="FooterGamesCount" Text="Games Loaded: 0" FontSize="11" Foreground="#6FA0A0A5"/>
                        <TextBlock Text="|" Foreground="#25FFFFFF" Margin="12,0,12,0"/>
                        <TextBlock x:Name="FooterStatus" Text="Ready" FontSize="11" Foreground="#0099FF"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="PCSX5 - PlayStation 5 Emulator v1.00" FontSize="10" Foreground="#3FA0A0A5" Margin="0,0,25,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- TOAST NOTIFICATION OVERLAY -->
            <Border x:Name="ToastNotification" Grid.RowSpan="3" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Background="#CC1A1D24" BorderBrush="#3300FF99" BorderThickness="1" CornerRadius="10"
                    Padding="18,10" Margin="0,0,0,50" Visibility="Collapsed" Opacity="0"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect Color="#00FF99" BlurRadius="20" Opacity="0.35" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✓" Foreground="#00FF99" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ToastMessage" Text="Configuration saved successfully" Foreground="#E0FFFFFF" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- CRASH DIAGNOSTICS OVERLAY DIALOG -->
            <Grid x:Name="CrashDialogOverlay" Visibility="Collapsed" Background="#D905060A" Grid.RowSpan="3">
                <Border Background="#1C1F26" BorderBrush="#CC2200" BorderThickness="1.5" CornerRadius="12" Width="550" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF2200" BlurRadius="25" Opacity="0.4" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="36" Height="36" Background="#20FF2200" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="⚠" Foreground="#FF3300" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CRASH DIAGNOSTICS" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Guest Application Exception Detected" FontSize="11" Foreground="#FFA0A0A5"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Details Area -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                            <StackPanel>
                                <!-- Summary Row -->
                                <Border Background="#26000000" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Exception Code: " Foreground="#FFA0A0A5" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="CrashExcCodeText" Grid.Row="0" Grid.Column="1" Text="0xC0000005 (Access Violation)" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Address (RIP): " Foreground="#FFA0A0A5" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock x:Name="CrashRipText" Grid.Row="1" Grid.Column="1" Text="0x800000080" Foreground="#0099FF" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                </Border>

                                <!-- Analysis -->
                                <TextBlock Text="AUTOMATED ANALYSIS:" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,6"/>
                                <Border Background="#100099FF" BorderBrush="#200099FF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                                    <TextBlock x:Name="CrashAnalysisText" TextWrapping="Wrap" Foreground="#FFD0D0D5" FontSize="12" LineHeight="18"
                                               Text="The guest application crashed at address 0x800000080 (Offset: 0x80). This indicates the binary contains encrypted segments or is executing garbage headers. You need to decrypt the executable first."/>
                                </Border>

                                <!-- Raw Logs -->
                                <TextBlock Text="CRASH DUMP EXTRACT:" FontSize="11" FontWeight="Bold" Foreground="#FFA0A0A5" Margin="0,0,0,6"/>
                                <TextBox x:Name="CrashRawText" IsReadOnly="True" Background="#15000000" Foreground="#FFA0A0A5" BorderThickness="0" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10" Padding="8" Height="100" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Dismiss" Width="100" Height="32" Style="{StaticResource SecondaryButtonStyle}" Click="DismissCrashDialog_Click" Margin="0,0,10,0"/>
                            <Button Content="Run Boot Analyzer" Width="180" Height="32" Style="{StaticResource ModernButtonStyle}" Click="AnalyzeCrashedGame_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
