<Window x:Class="Pcsx5Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Pcsx5Ui"
        Title="PCSX5 - PlayStation 5 Emulator" Height="780" Width="1200"
        MinWidth="1050" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#0A0D14"
        Foreground="White"
        FontFamily="Segoe UI Semibold, Inter, Outfit, Arial"
        Loaded="Window_Loaded"
        Icon="pcsx5_icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" 
                      CornerRadius="12" 
                      CaptionHeight="50" 
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Modern Windows 11 style global resources -->
        <SolidColorBrush x:Key="SystemAccentBrush" Color="#0099FF"/>
        <SolidColorBrush x:Key="AccentGlowBrush" Color="#3F0099FF"/>
        <SolidColorBrush x:Key="GlassBackgroundBrush" Color="#CC0A0D14"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#3F000000"/>

        <!-- Controller input overlay styles: hidden until the matching button is pressed -->
        <Style x:Key="PadOverlayStyle" TargetType="Shape">
            <Setter Property="Fill" Value="#550099FF"/>
            <Setter Property="Stroke" Value="#0099FF"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style x:Key="PadOverlayRingStyle" TargetType="Shape">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="#0099FF"/>
            <Setter Property="StrokeThickness" Value="3"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>
        
        <!-- Navigation tab button style -->
        <Style x:Key="NavTabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFA0A0A5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="20,0,20,0"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Standard Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1EFFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8,15,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3DFFFFFF"/>
                    <Setter Property="BorderBrush" Value="#4FFFFFFF"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#3F0099FF"/>
                    <Setter Property="BorderBrush" Value="#0099FF"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F242F"/>
            <Setter Property="Foreground" Value="#FFA0A0A5"/>
            <Setter Property="BorderBrush" Value="#2A2F3D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,5,15,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2F3D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#3F0099FF"/>
                    <Setter Property="BorderBrush" Value="#0099FF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Global Controller Focus Style for ComboBox, Slider, CheckBox -->
        <Style TargetType="ComboBox">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0099FF"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Slider">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#3F0099FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Foreground" Value="#0099FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Animated spinner keyframe -->
        <Style x:Key="SpinnerStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#0099FF"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Immersive Full Window Background Image with opacity -->
        <Image x:Name="WindowBgImage" Stretch="UniformToFill" Opacity="0.28" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Image.Effect>
                <BlurEffect Radius="15" KernelType="Gaussian"/>
            </Image.Effect>
        </Image>
        
        <!-- Dark gradient overlay to fade the background art to black at the edges -->
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Color="#8F0A0D14" Offset="0.0"/>
                        <GradientStop Color="#BF0A0D14" Offset="0.6"/>
                        <GradientStop Color="#FD05060A" Offset="1.0"/>
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <!-- Main Window Layout -->
        <Grid x:Name="MainLayoutRoot" Margin="0">
            <Grid.RowDefinitions>
                <!-- Title Bar & Navigation -->
                <RowDefinition Height="65"/>
                <!-- Content Area -->
                <RowDefinition Height="*"/>
                <!-- Status/Footer Bar -->
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Title Bar & Navigation Grid -->
            <Border x:Name="TitleBarBorder" Grid.Row="0" Background="#4F05060A" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <TextBlock Text="PCSX5" Foreground="#0099FF" FontSize="20" FontWeight="ExtraBold" VerticalAlignment="Center"/>
                        <TextBlock Text="PS5" Foreground="#A0A0A5" FontSize="11" Margin="8,4,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Navigation Tabs -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="TabLibraryBtn" Content="GAME LIBRARY" Style="{StaticResource NavTabButtonStyle}" Click="TabLibrary_Click"/>
                        <Button x:Name="TabAnalyzerBtn" Content="BOOT ANALYZER" Style="{StaticResource NavTabButtonStyle}" Click="TabAnalyzer_Click"/>
                        <Button x:Name="TabControllerBtn" Content="CONTROLLER SETUP" Style="{StaticResource NavTabButtonStyle}" Click="TabController_Click"/>
                        <Button x:Name="TabSettingsBtn" Content="SYSTEM SETTINGS" Style="{StaticResource NavTabButtonStyle}" Click="TabSettings_Click"/>
                    </StackPanel>

                    <!-- Top-Right Controls & Search Box -->
                    <Grid Grid.Column="2" VerticalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button x:Name="BtnMinimize" Content="⚊" Width="42" Height="26" Background="Transparent" Foreground="#D0FFFFFF" BorderThickness="0" FontSize="11" Click="Minimize_Click" Style="{x:Null}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnMaximize" Content="🗖" Width="42" Height="26" Background="Transparent" Foreground="#D0FFFFFF" BorderThickness="0" FontSize="10" Click="Maximize_Click" Style="{x:Null}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button x:Name="BtnClose" Content="✕" Width="42" Height="26" Background="Transparent" Foreground="#D0FFFFFF" BorderThickness="0" FontSize="11" Click="Close_Click" Style="{x:Null}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <!-- Search box below controls -->
                        <Grid Width="200" Height="30" Margin="0,0,25,6" HorizontalAlignment="Right" VerticalAlignment="Bottom" WindowChrome.IsHitTestVisibleInChrome="True">
                            <!-- Background Pill -->
                            <Border x:Name="SearchBoxBorder" CornerRadius="15" Background="#2FFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Search Icon -->
                                    <TextBlock Grid.Column="0" Text="🔍" Foreground="#FFA0A0A5" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <!-- TextBox -->
                                    <TextBox x:Name="SearchBox" Grid.Column="1" Background="Transparent" Foreground="White" BorderThickness="0" VerticalAlignment="Center" VerticalContentAlignment="Center" Padding="0,0,10,0" FontSize="11" FontWeight="SemiBold" GotFocus="SearchBox_GotFocus" LostFocus="SearchBox_LostFocus" TextChanged="SearchBox_TextChanged"/>
                                    <!-- Placeholder Text -->
                                    <TextBlock x:Name="SearchPlaceholder" Grid.Column="1" Text="Search Games..." Foreground="#6FA0A0A5" FontSize="11" VerticalAlignment="Center" Padding="0,0,10,0" IsHitTestVisible="False" Visibility="Visible"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- CONTENT VIEWS -->
            <Grid Grid.Row="1">
                
                <!-- 1. GAME LIBRARY VIEW (GRID) -->
                <Grid x:Name="LibraryView" Visibility="Visible" Margin="0">
                    <Grid.RowDefinitions>
                        <!-- Upper details area -->
                        <RowDefinition Height="*"/>
                        <!-- Lower carousel shelf -->
                        <RowDefinition Height="265"/>
                    </Grid.RowDefinitions>

                    <!-- Upper details area: details about selected game -->
                    <Grid Grid.Row="0" Margin="40,25,40,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/> <!-- Text Details -->
                            <ColumnDefinition Width="1*"/>   <!-- Mini Cover Display -->
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Big Game Title & Play Controls -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <!-- Game Title -->
                            <TextBlock x:Name="DetailTitle" Text="Select a Game" FontSize="42" FontWeight="ExtraBold" Foreground="White" TextWrapping="Wrap" LineHeight="48"/>
                            
                            <!-- Metadata badges & ID -->
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,20">
                                <TextBlock x:Name="DetailTitleId" Text="No game selected" FontSize="13" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                                <TextBlock Text="•" Foreground="#FFA0A0A5" Margin="10,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DetailSize" Text="-" FontSize="13" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                                <TextBlock Text="•" Foreground="#FFA0A0A5" Margin="10,0,10,0" VerticalAlignment="Center"/>
                                
                                <Border x:Name="DetailCompatBadge" Padding="8,3,8,3" CornerRadius="4" Background="#3F555555" VerticalAlignment="Center">
                                    <TextBlock x:Name="DetailCompatText" Text="UNKNOWN" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <!-- Path info -->
                            <TextBlock Text="Executable Path:" FontSize="11" Foreground="#6FA0A0A5" Margin="0,0,0,3"/>
                            <TextBlock x:Name="DetailPath" Text="-" FontSize="11" Foreground="#FFA0A0A5" TextWrapping="Wrap" MaxHeight="45" Margin="0,0,0,25"/>

                            <!-- Play/Launch Button -->
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="LaunchButton" Content="Play Game" Width="200" Height="48" FontSize="15" FontWeight="Bold" Cursor="Hand" Click="LaunchButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#0078D4"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="24" BorderBrush="#3FFFFFFF" BorderThickness="1">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="#0078D4" BlurRadius="15" Opacity="0.5" ShadowDepth="0"/>
                                                            </Border.Effect>
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0099FF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Button x:Name="StopButton" Content="Stop" Width="100" Height="48" FontSize="15" FontWeight="Bold" Margin="15,0,0,0" Cursor="Hand" Visibility="Collapsed" Click="StopButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#CC2200"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="24" BorderBrush="#3FFFFFFF" BorderThickness="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FF3300"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right Column: Visual Art Preview of Selected Game -->
                        <Border x:Name="GameCoverDisplayBorder" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Width="220" Height="220" CornerRadius="12" BorderBrush="#2FFFFFFF" BorderThickness="1" Background="#1F000000"/>
                    </Grid>

                    <!-- Lower Carousel shelf: horizontal scrolling game icons -->
                    <Grid Grid.Row="1" Background="#2F05060A">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock x:Name="LibraryHeaderTextBlock" Grid.Row="0" Text="Game Library" FontSize="13" FontWeight="Bold" Foreground="#FFA0A0A5" Margin="40,15,40,5"/>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Style="{StaticResource ModernScrollViewer}" Padding="35,0,35,0">
                            <StackPanel x:Name="GamesWrapPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="200"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
                
                <!-- 1.5. BOOT ANALYZER VIEW (GRID) -->
                <Grid x:Name="AnalyzerView" Visibility="Collapsed" Margin="40,20,40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Top Buttons -->
                        <RowDefinition Height="*"/>    <!-- Main Split Area -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="AnalyzerHeaderTextBlock" Text="Executable Boot &amp; Memory Analyzer" FontSize="14" FontWeight="Bold" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Analyze All Games" Style="{StaticResource ModernButtonStyle}" Click="AnalyzeAll_Click"/>
                            <Button Content="Export Minimal Summary" Style="{StaticResource ModernButtonStyle}" Margin="10,0,0,0" Click="ExportSummary_Click"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.8*"/> <!-- Left: ListView -->
                            <ColumnDefinition Width="1.2*"/> <!-- Right: Selected Game Details / Log -->
                        </Grid.ColumnDefinitions>

                        <!-- ListView -->
                        <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Margin="0,0,10,0">
                            <ListView x:Name="AnalyzerListView" Background="Transparent" Foreground="White" BorderThickness="0" SelectionChanged="AnalyzerListView_SelectionChanged">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Game Title" Width="180" DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="Title ID" Width="80" DisplayMemberBinding="{Binding TitleId}"/>
                                        <GridViewColumn Header="Format" Width="90" DisplayMemberBinding="{Binding Format}"/>
                                        <GridViewColumn Header="Encryption" Width="100" DisplayMemberBinding="{Binding EncryptionStatus}"/>
                                        <GridViewColumn Header="Footprint" Width="80" DisplayMemberBinding="{Binding MemoryFootprint}"/>
                                        <GridViewColumn Header="Alignment" Width="80" DisplayMemberBinding="{Binding AlignmentStatus}"/>
                                    </GridView>
                                </ListView.View>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Margin" Value="0,2,0,2"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3F0099FF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#20FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Border>

                        <!-- Raw Log View on the Right -->
                        <Border Grid.Column="1" Background="#E0050508" BorderBrush="#1EFFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Detailed Parser Analysis Log" FontSize="11" Foreground="#FFA0A0A5" Margin="0,0,0,8"/>
                                <TextBox x:Name="AnalyzerOutputTextBox" Grid.Row="1" Background="Transparent" Foreground="#FFCC66" FontFamily="Consolas, Courier New" FontSize="10.5" 
                                         BorderThickness="0" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True" AcceptsReturn="True"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
                
                <!-- 1.7. CONTROLLER SETUP VIEW (GRID) -->
                <Grid x:Name="ControllerView" Visibility="Collapsed" Margin="40,10,40,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Controller Setup" FontSize="14" FontWeight="Bold" Foreground="#FFA0A0A5" Margin="0,0,0,5"/>

                    <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Left side mapping (D-Pad, L1/L2, Left Stick, Deadzone) -->
                                <ColumnDefinition Width="260"/>
                                <!-- Center side (Config Selection, DualSense Image, Touchpad, Color, Save buttons) -->
                                <ColumnDefinition Width="*"/>
                                <!-- Right side mapping (Face buttons, R1/R2, Right Stick, Deadzone) -->
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>

                            <!-- COLUMN 0: LEFT SIDE MAPPINGS -->
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,0,10,0">
                                    <!-- D-PAD CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="D-Pad" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Up" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapUp" Content="pad_up" Tag="PadUp" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Left" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapLeft" Content="pad_left" Tag="PadLeft" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Right" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapRight" Content="pad_right" Tag="PadRight" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Down" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapDown" Content="pad_down" Tag="PadDown" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- L1 and L2 CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="L1 and L2" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="L1" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapL1" Content="l1" Tag="L1" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="L2" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapL2" Content="l2" Tag="L2" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- LEFT STICK DEADZONE CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Left Stick Deadzone" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <TextBlock Text="Min Deadzone (def: 2 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMinDeadzoneLSlider" Minimum="0" Maximum="127" Value="2" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMinDeadzoneLSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Max Deadzone (def: 127 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMaxDeadzoneLSlider" Minimum="0" Maximum="127" Value="127" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMaxDeadzoneLSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- LEFT STICK CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Left Stick" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Up" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapLeftStickUp" Content="axis_left_y" Tag="LeftStickUp" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Left" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapLeftStickLeft" Content="axis_left_x" Tag="LeftStickLeft" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Right" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapLeftStickRight" Content="axis_left_x" Tag="LeftStickRight" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Down" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapLeftStickDown" Content="axis_left_y" Tag="LeftStickDown" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- COLUMN 1: CENTER AREA -->
                            <Grid Grid.Column="1" Margin="10,0,10,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Config selection -->
                                    <RowDefinition Height="*"/>    <!-- PS5 image -->
                                    <RowDefinition Height="Auto"/> <!-- Bottom buttons (L3, Options, R3, etc.) -->
                                    <RowDefinition Height="Auto"/> <!-- Color adjustment -->
                                    <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                                    <RowDefinition Height="Auto"/> <!-- Live Input Tester panel -->
                                </Grid.RowDefinitions>

                                <!-- Config Selection Card -->
                                <Border Grid.Row="0" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Text="Config Selection" FontSize="11" FontWeight="Bold" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                        
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <ComboBox x:Name="CtrlConfigCombo" SelectedIndex="0" Width="140" Height="24" Background="#2FFFFFFF" Foreground="Black">
                                                <ComboBoxItem Content="Common Config"/>
                                            </ComboBox>
                                            <CheckBox x:Name="CtrlUsePerGameConfigCheck" Content="Use per-game configs" Foreground="White" Margin="15,0,0,0" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                            <TextBlock Text="Active Gamepad:" Foreground="#FFA0A0A5" VerticalAlignment="Center" FontSize="11" Margin="0,0,10,0"/>
                                            <ComboBox x:Name="CtrlActiveGamepadCombo" SelectedIndex="0" Width="200" Height="24" Background="#2FFFFFFF" Foreground="Black" SelectionChanged="CtrlActiveGamepadCombo_SelectionChanged">
                                                <ComboBoxItem Content="Player 1: DualSense Wireless Controller"/>
                                                <ComboBoxItem Content="Player 2: Controller Slot 2"/>
                                                <ComboBoxItem Content="Player 3: Controller Slot 3"/>
                                                <ComboBoxItem Content="Player 4: Controller Slot 4"/>
                                                <ComboBoxItem Content="Xbox Controller (XInput)"/>
                                            </ComboBox>
                                            <Button Content="Set Active Gamepad as Default" Style="{StaticResource ModernButtonStyle}" Height="24" FontSize="10" Padding="8,0,8,0" Margin="10,0,0,0" Click="SaveSettingsBtn_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Controller Image with live input overlays (1017x1017 design space, scaled by the Viewbox) -->
                                <Grid Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="260">
                                    <Viewbox Stretch="Uniform">
                                        <Grid Width="1017" Height="1017">
                                            <Image Source="ps5_controller.png" Stretch="Uniform" Opacity="0.85"/>
                                            <Canvas x:Name="ControllerOverlayCanvas" Width="1017" Height="1017" IsHitTestVisible="False">
                                                <!-- Triggers / bumpers -->
                                                <Rectangle x:Name="PadL2Overlay" Canvas.Left="168" Canvas.Top="200" Width="110" Height="30" RadiusX="14" RadiusY="14" Style="{StaticResource PadOverlayStyle}"/>
                                                <Rectangle x:Name="PadR2Overlay" Canvas.Left="739" Canvas.Top="200" Width="110" Height="30" RadiusX="14" RadiusY="14" Style="{StaticResource PadOverlayStyle}"/>
                                                <Rectangle x:Name="PadL1Overlay" Canvas.Left="173" Canvas.Top="238" Width="100" Height="26" RadiusX="12" RadiusY="12" Style="{StaticResource PadOverlayStyle}"/>
                                                <Rectangle x:Name="PadR1Overlay" Canvas.Left="744" Canvas.Top="238" Width="100" Height="26" RadiusX="12" RadiusY="12" Style="{StaticResource PadOverlayStyle}"/>

                                                <!-- Touchpad zones -->
                                                <Rectangle x:Name="PadTouchLeftOverlay" Canvas.Left="402" Canvas.Top="268" Width="76" Height="150" RadiusX="10" RadiusY="10" Style="{StaticResource PadOverlayStyle}"/>
                                                <Rectangle x:Name="PadTouchCenterOverlay" Canvas.Left="482" Canvas.Top="268" Width="80" Height="150" RadiusX="10" RadiusY="10" Style="{StaticResource PadOverlayStyle}"/>
                                                <Rectangle x:Name="PadTouchRightOverlay" Canvas.Left="566" Canvas.Top="268" Width="76" Height="150" RadiusX="10" RadiusY="10" Style="{StaticResource PadOverlayStyle}"/>

                                                <!-- Create (Back) / Options -->
                                                <Ellipse x:Name="PadBackOverlay" Canvas.Left="362" Canvas.Top="329" Width="26" Height="26" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadOptionsOverlay" Canvas.Left="653" Canvas.Top="329" Width="26" Height="26" Style="{StaticResource PadOverlayStyle}"/>

                                                <!-- D-Pad -->
                                                <Ellipse x:Name="PadUpOverlay" Canvas.Left="204" Canvas.Top="292" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadLeftOverlay" Canvas.Left="160" Canvas.Top="348" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadRightOverlay" Canvas.Left="246" Canvas.Top="348" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadDownOverlay" Canvas.Left="204" Canvas.Top="404" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>

                                                <!-- Face buttons -->
                                                <Ellipse x:Name="PadTriangleOverlay" Canvas.Left="785" Canvas.Top="292" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadSquareOverlay" Canvas.Left="729" Canvas.Top="348" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadCircleOverlay" Canvas.Left="841" Canvas.Top="348" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>
                                                <Ellipse x:Name="PadCrossOverlay" Canvas.Left="785" Canvas.Top="404" Width="36" Height="36" Style="{StaticResource PadOverlayStyle}"/>

                                                <!-- PS Logo / Mute LED -->
                                                <Ellipse x:Name="PadPsOverlay" Canvas.Left="495" Canvas.Top="500" Width="28" Height="28" Style="{StaticResource PadOverlayStyle}"/>
                                                <Rectangle x:Name="PadMuteOverlay" Canvas.Left="499" Canvas.Top="538" Width="20" Height="8" RadiusX="3" RadiusY="3" Fill="#FF6600" Opacity="0"/>

                                                <!-- Stick wells + moving stick dots + L3/R3 rings -->
                                                <Ellipse Canvas.Left="360" Canvas.Top="456" Width="84" Height="84" Fill="#100099FF" Stroke="#300099FF" StrokeThickness="1"/>
                                                <Ellipse Canvas.Left="599" Canvas.Top="456" Width="84" Height="84" Fill="#100099FF" Stroke="#300099FF" StrokeThickness="1"/>
                                                <Ellipse x:Name="PadL3Overlay" Canvas.Left="360" Canvas.Top="456" Width="84" Height="84" Style="{StaticResource PadOverlayRingStyle}"/>
                                                <Ellipse x:Name="PadR3Overlay" Canvas.Left="599" Canvas.Top="456" Width="84" Height="84" Style="{StaticResource PadOverlayRingStyle}"/>
                                                <Ellipse x:Name="LeftStickDot" Canvas.Left="384" Canvas.Top="480" Width="36" Height="36" Fill="#990099FF" Stroke="#CCFFFFFF" StrokeThickness="1.5"/>
                                                <Ellipse x:Name="RightStickDot" Canvas.Left="623" Canvas.Top="480" Width="36" Height="36" Fill="#990099FF" Stroke="#CCFFFFFF" StrokeThickness="1.5"/>

                                                <!-- Touch finger dots -->
                                                <Ellipse x:Name="TouchDot0" Canvas.Left="0" Canvas.Top="0" Width="14" Height="14" Fill="#FFFFCC00" Stroke="#FFFFFFFF" StrokeThickness="1.5" Visibility="Hidden"/>
                                                <Ellipse x:Name="TouchDot1" Canvas.Left="0" Canvas.Top="0" Width="14" Height="14" Fill="#FFFFCC00" Stroke="#FFFFFFFF" StrokeThickness="1.5" Visibility="Hidden"/>
                                            </Canvas>
                                        </Grid>
                                    </Viewbox>
                                </Grid>

                                <!-- Bottom buttons (L3, Options, R3, Touchpad) -->
                                <Border Grid.Row="2" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="2,0,2,0">
                                            <TextBlock Text="L3" FontSize="10" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button x:Name="BtnMapL3" Content="l3" Tag="L3" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="2,0,2,0">
                                            <TextBlock Text="Options" FontSize="10" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button x:Name="BtnMapOptions" Content="options" Tag="Options" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Grid.Row="0" Margin="2,0,2,0">
                                            <TextBlock Text="R3" FontSize="10" Foreground="#0099FF" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button x:Name="BtnMapR3" Content="r3" Tag="R3" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="2,5,2,0">
                                            <TextBlock Text="Touchpad Left" FontSize="10" Foreground="#FFA0A0A5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button x:Name="BtnMapTouchpadLeft" Content="unmapped" Tag="TouchpadLeft" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="2,5,2,0">
                                            <TextBlock Text="Touchpad Center" FontSize="10" Foreground="#FFA0A0A5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button x:Name="BtnMapTouchpadCenter" Content="back" Tag="TouchpadCenter" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Grid.Row="1" Margin="2,5,2,0">
                                            <TextBlock Text="Touchpad Right" FontSize="10" Foreground="#FFA0A0A5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <Button x:Name="BtnMapTouchpadRight" Content="unmapped" Tag="TouchpadRight" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Color Adjustment & Rumble Card -->
                                <Border Grid.Row="3" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Color Adjustment &amp; Haptics" FontSize="10" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,4"/>
                                            
                                            <!-- RED -->
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="RED" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                                                <Slider x:Name="CtrlColorRSlider" Minimum="0" Maximum="255" Value="0" TickFrequency="16" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center" ValueChanged="CtrlColorSliders_ValueChanged"/>
                                            </Grid>
                                            
                                            <!-- GREEN -->
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="GREEN" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                                                <Slider x:Name="CtrlColorGSlider" Minimum="0" Maximum="255" Value="0" TickFrequency="16" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center" ValueChanged="CtrlColorSliders_ValueChanged"/>
                                            </Grid>
                                            
                                            <!-- BLUE -->
                                            <Grid Margin="0,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="35"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="BLUE" FontSize="9" Foreground="White" VerticalAlignment="Center"/>
                                                <Slider x:Name="CtrlColorBSlider" Minimum="0" Maximum="255" Value="255" TickFrequency="16" IsSnapToTickEnabled="True" Grid.Column="1" VerticalAlignment="Center" ValueChanged="CtrlColorSliders_ValueChanged"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <CheckBox x:Name="CtrlOverrideColorCheck" Content="Override Color" Foreground="White" FontSize="10" IsChecked="True" Margin="0,0,0,6"/>
                                            <Border Background="Blue" Height="24" BorderBrush="White" BorderThickness="1" CornerRadius="4" x:Name="CtrlColorBox"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Bottom actions -->
                                <Grid Grid.Row="4" Margin="0,5,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button x:Name="RestoreDefaultMappingsBtn" Content="Restore Defaults" Style="{StaticResource ModernButtonStyle}" Width="110" Height="26" FontSize="10" Padding="0" Click="RestoreDefaultMappings_Click"/>
                                        <Button x:Name="TestRumbleBtn" Content="Vibration Test" Style="{StaticResource ModernButtonStyle}" Width="100" Height="26" FontSize="10" Padding="0" Margin="6,0,0,0" Click="TestRumbleBtn_Click" ToolTip="Sends a haptic pulse to connected DualSense controller"/>
                                        <Button x:Name="ToggleMicBtn" Content="Toggle Mic LED" Style="{StaticResource ModernButtonStyle}" Width="100" Height="26" FontSize="10" Padding="0" Margin="6,0,0,0" Click="ToggleMicBtn_Click" ToolTip="Toggles controller microphone mute LED"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Save" Style="{StaticResource ModernButtonStyle}" Width="65" Height="26" FontSize="10" Padding="0" Click="SaveSettingsBtn_Click"/>
                                        <Button Content="Cancel" Style="{StaticResource ModernButtonStyle}" Width="65" Height="26" FontSize="10" Padding="0" Margin="6,0,0,0"/>
                                        <Button Content="Apply" Style="{StaticResource ModernButtonStyle}" Width="65" Height="26" FontSize="10" Padding="0" Margin="6,0,0,0" Click="SaveSettingsBtn_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- LIVE INPUT TESTER PANEL (in-app replacement for dualsense_visual.exe) -->
                                <Border x:Name="ControllerTesterPanel" Grid.Row="5" Visibility="Collapsed" Background="#15FFFFFF" BorderBrush="#200099FF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,10,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- LEFT: digital + analog input readouts -->
                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="LIVE INPUT" FontSize="10" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="TesterConnectionText" Text="No controller connected" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="TesterButtonsText" Text="Buttons: -" FontSize="10" Foreground="White" Margin="0,0,0,8" TextWrapping="Wrap" FontFamily="Consolas"/>

                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="34"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="L2" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                                                <ProgressBar x:Name="TesterL2Bar" Grid.Column="1" Minimum="0" Maximum="255" Height="10" Background="#20FFFFFF" Foreground="#0099FF"/>
                                                <TextBlock x:Name="TesterL2Text" Grid.Column="2" Text="0" FontSize="10" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="34"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="R2" FontSize="10" Foreground="White" VerticalAlignment="Center"/>
                                                <ProgressBar x:Name="TesterR2Bar" Grid.Column="1" Minimum="0" Maximum="255" Height="10" Background="#20FFFFFF" Foreground="#0099FF"/>
                                                <TextBlock x:Name="TesterR2Text" Grid.Column="2" Text="0" FontSize="10" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas"/>
                                            </Grid>

                                            <TextBlock x:Name="TesterLeftStickText" Text="Left Stick:  X=128 Y=128" FontSize="10" Foreground="White" Margin="0,0,0,2" FontFamily="Consolas"/>
                                            <TextBlock x:Name="TesterRightStickText" Text="Right Stick: X=128 Y=128" FontSize="10" Foreground="White" Margin="0,0,0,2" FontFamily="Consolas"/>
                                            <TextBlock x:Name="TesterTouchText" Text="Touchpad: released" FontSize="10" Foreground="White" Margin="0,0,0,2" FontFamily="Consolas"/>
                                            <TextBlock x:Name="TesterGyroText" Text="Gyro:  -" FontSize="10" Foreground="White" Margin="0,0,0,2" FontFamily="Consolas"/>
                                            <TextBlock x:Name="TesterAccelText" Text="Accel: -" FontSize="10" Foreground="White" FontFamily="Consolas"/>
                                        </StackPanel>

                                        <!-- RIGHT: output tests (rumble, LEDs, lightbar, adaptive triggers) -->
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                            <TextBlock Text="OUTPUT TESTS" FontSize="10" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,6"/>

                                            <TextBlock Text="Rumble" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Button Content="Low Freq" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Click="TesterRumbleLow_Click"/>
                                                <Button Content="High Freq" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterRumbleHigh_Click"/>
                                                <Button Content="Stop" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterRumbleStop_Click"/>
                                            </StackPanel>

                                            <TextBlock Text="Lightbar &amp; Player LEDs" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Button Content="Set Lightbar Color" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Click="TesterLightbarApply_Click" ToolTip="Applies the RED/GREEN/BLUE slider values to the controller lightbar"/>
                                                <Button Content="Reset" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterLightbarReset_Click"/>
                                                <Button Content="Cycle Player LED" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterPlayerLed_Click"/>
                                            </StackPanel>

                                            <TextBlock Text="Adaptive Triggers (both L2/R2)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button Content="Off" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Click="TesterTriggerOff_Click"/>
                                                <Button Content="Feedback" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterTriggerFeedback_Click"/>
                                                <Button Content="Weapon" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterTriggerWeapon_Click"/>
                                                <Button Content="Vibration" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterTriggerVibration_Click"/>
                                            </StackPanel>
                                            <TextBlock Text="Speaker &amp; Microphone (USB only)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button Content="Play Test Tone" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Click="TesterPlayTone_Click" ToolTip="Plays a 440 Hz tone through the DualSense speaker (USB audio endpoint, channels 1-2)"/>
                                                <Button x:Name="TesterMicTestBtn" Content="Mic Test" Style="{StaticResource ModernButtonStyle}" Height="22" FontSize="9" Padding="6,0,6,0" Margin="4,0,0,0" Click="TesterMicTest_Click" ToolTip="Live level meter from the DualSense microphone (USB only)"/>
                                                <ProgressBar x:Name="TesterMicLevelBar" Minimum="0" Maximum="100" Width="80" Height="10" Background="#20FFFFFF" Foreground="#0099FF" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock x:Name="TesterStatusText" Text="" FontSize="9" Foreground="#FFCC66" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- COLUMN 2: RIGHT SIDE MAPPINGS -->
                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="10,0,0,0">
                                    <!-- FACE BUTTONS CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Face Buttons" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Triangle" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapTriangle" Content="triangle" Tag="Triangle" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Circle" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapCircle" Content="circle" Tag="Circle" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Cross" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapCross" Content="cross" Tag="Cross" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Square" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapSquare" Content="square" Tag="Square" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- R1 and R2 CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="R1 and R2" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="R1" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapR1" Content="r1" Tag="R1" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="R2" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapR2" Content="r2" Tag="R2" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- RIGHT STICK DEADZONE CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Right Stick Deadzone" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <TextBlock Text="Min Deadzone (def: 2 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMinDeadzoneRSlider" Minimum="0" Maximum="127" Value="2" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMinDeadzoneRSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="Max Deadzone (def: 127 max: 127)" FontSize="10" Foreground="#FFA0A0A5" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="CtrlMaxDeadzoneRSlider" Minimum="0" Maximum="127" Value="127" TickFrequency="5" IsSnapToTickEnabled="True" Grid.Column="0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ElementName=CtrlMaxDeadzoneRSlider, Path=Value}" Foreground="White" FontWeight="Bold" FontSize="10" HorizontalAlignment="Right" Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- RIGHT STICK CARD -->
                                    <Border Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Right Stick" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,8"/>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Up" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapRightStickUp" Content="axis_right_y" Tag="RightStickUp" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Left" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapRightStickLeft" Content="axis_right_x" Tag="RightStickLeft" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Right" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapRightStickRight" Content="axis_right_x" Tag="RightStickRight" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Grid Margin="0,2,0,2">
                                                <TextBlock Text="Down" Foreground="White" VerticalAlignment="Center" FontSize="11"/>
                                                <Button x:Name="BtnMapRightStickDown" Content="axis_right_y" Tag="RightStickDown" Click="BtnMap_Click" Style="{StaticResource ModernButtonStyle}" Width="120" Height="22" FontSize="10" Padding="0" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                
                <!-- 2. SYSTEM SETTINGS VIEW (GRID) -->
                <Grid x:Name="SettingsView" Visibility="Collapsed" Margin="40,20,40,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,15,0">
                            
                            <!-- GAME DIRECTORIES CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="GAME DIRECTORIES" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="120"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Folder ListBox -->
                                        <ListBox x:Name="GameFoldersListBox" Grid.Row="0" Background="#20FFFFFF" Foreground="White" BorderBrush="#15FFFFFF" BorderThickness="1">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="5"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                        </ListBox>
                                        
                                        <!-- Actions -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button x:Name="BtnAddFolder" Content="Add Folder" Style="{StaticResource ModernButtonStyle}" Width="110" Click="BtnAddFolder_Click"/>
                                            <Button x:Name="BtnRemoveFolder" Content="Remove Selected" Style="{StaticResource ModernButtonStyle}" Width="140" Margin="10,0,0,0" Click="BtnRemoveFolder_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- GRAPHICS CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="GRAPHICS SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Renderer -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Renderer API" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="GpuRendererCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="Vulkan"/>
                                            <ComboBoxItem Content="OpenGL (Experimental)"/>
                                        </ComboBox>

                                        <!-- Fullscreen -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Start in Fullscreen" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="GpuFullscreenCheck" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Resolution Scale -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Resolution Scale" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="GpuResScaleSlider" Width="150" Minimum="0.5" Maximum="2.0" TickFrequency="0.25" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="GpuResScaleSlider_ValueChanged"/>
                                            <TextBlock x:Name="GpuResScaleText" Text="1.0x" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Custom Window Dimensions -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Default Window Size (W x H)" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBox x:Name="GpuWidthText" Width="60" Height="24" Background="#20FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#15FFFFFF" VerticalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Text="x" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                            <TextBox x:Name="GpuHeightText" Width="60" Height="24" Background="#20FFFFFF" Foreground="White" BorderThickness="1" BorderBrush="#15FFFFFF" VerticalAlignment="Center" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- AUDIO CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="AUDIO SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Audio Backend -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Audio Output Backend" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="SndBackendCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="Null Driver (No Audio)"/>
                                            <ComboBoxItem Content="WASAPI"/>
                                            <ComboBoxItem Content="XAudio2"/>
                                        </ComboBox>

                                        <!-- Audio Volume -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Volume" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="SndVolumeSlider" Width="150" Minimum="0" Maximum="1" TickFrequency="0.1" VerticalAlignment="Center" ValueChanged="SndVolumeSlider_ValueChanged"/>
                                            <TextBlock x:Name="SndVolumeText" Text="100%" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Audio Buffer -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Audio Buffer Latency" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="SndBufferSlider" Width="150" Minimum="10" Maximum="200" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SndBufferSlider_ValueChanged"/>
                                            <TextBlock x:Name="SndBufferText" Text="50 ms" Width="50" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Title Music Preview -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Enable Title Screen Background Music" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="SndTitleMusicCheck" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Click="SndTitleMusicCheck_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- INPUT CONTROLLER CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="INPUT SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Input Backend -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Gamepad Input Backend" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="InBackendCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="SDL Controller"/>
                                            <ComboBoxItem Content="XInput Controller"/>
                                        </ComboBox>

                                        <!-- Deadzone -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Analog Stick Deadzone" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="InDeadzoneSlider" Width="150" Minimum="0" Maximum="0.5" TickFrequency="0.05" VerticalAlignment="Center" ValueChanged="InDeadzoneSlider_ValueChanged"/>
                                            <TextBlock x:Name="InDeadzoneText" Text="15%" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Rumble -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Enable Controller Rumble" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="InRumbleCheck" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- HLE & COMPILER CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="SYSTEM &amp; EMULATION SETTINGS (HLE)" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Strict Imports -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Strict Symbol Imports Verification" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="HleStrictCheck" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Trace Calls -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Trace Function Calls" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="HleTraceCheck" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- Trace Capacity -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Trace Ring Buffer Capacity" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <Slider x:Name="HleTraceCapSlider" Width="150" Minimum="64" Maximum="1024" TickFrequency="64" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="HleTraceCapSlider_ValueChanged"/>
                                            <TextBlock x:Name="HleTraceCapText" Text="256" Width="40" Margin="10,0,0,0" TextAlignment="Right" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Write Minidump -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Write Crash Minidump" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="HleWriteDumpCheck" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- LOGGING CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="LOGGING SETTINGS" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>

                                        <!-- Log level -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Minimum Log Verbosity Level" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="LogMinLevelCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="Trace"/>
                                            <ComboBoxItem Content="Debug"/>
                                            <ComboBoxItem Content="Info"/>
                                            <ComboBoxItem Content="Warning"/>
                                            <ComboBoxItem Content="Error"/>
                                            <ComboBoxItem Content="Fatal"/>
                                        </ComboBox>

                                        <!-- Append log file -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Append to Existing Log File" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="LogFileAppendCheck" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- JSON Output -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Format Log Output as JSON" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <CheckBox x:Name="LogJsonCheck" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- UI SETTINGS CARD -->
                            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock x:Name="UiLocalizationHeaderTextBlock" Text="UI &amp; LOCALIZATION" FontSize="14" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                            <RowDefinition Height="Auto" MinHeight="35"/>
                                        </Grid.RowDefinitions>
                                        
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Interface Language" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="UiLanguageCombo" Grid.Row="0" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black">
                                            <ComboBoxItem Content="English (United States)" Tag="en-US"/>
                                            <ComboBoxItem Content="Deutsch (Deutschland)" Tag="de-DE"/>
                                            <ComboBoxItem Content="Español (España)" Tag="es-ES"/>
                                            <ComboBoxItem Content="Français (France)" Tag="fr-FR"/>
                                            <ComboBoxItem Content="Italiano (Italia)" Tag="it-IT"/>
                                            <ComboBoxItem Content="日本語 (日本)" Tag="ja-JP"/>
                                            <ComboBoxItem Content="한국어 (대한민국)" Tag="ko-KR"/>
                                            <ComboBoxItem Content="Português (Brasil)" Tag="pt-BR"/>
                                            <ComboBoxItem Content="Русский (Россия)" Tag="ru-RU"/>
                                            <ComboBoxItem Content="简体中文 (中国)" Tag="zh-CN"/>
                                            <ComboBoxItem Content="繁體中文 (台灣)" Tag="zh-TW"/>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="UI Scale (Font &amp; Layout Size)" VerticalAlignment="Center" Foreground="#FFA0A0A5"/>
                                        <ComboBox x:Name="UiScaleCombo" Grid.Row="1" Grid.Column="1" Width="200" Height="26" HorizontalAlignment="Right" Background="#20FFFFFF" Foreground="Black" SelectionChanged="UiScaleCombo_SelectionChanged">
                                            <ComboBoxItem Content="80%" Tag="0.8"/>
                                            <ComboBoxItem Content="100% (Default)" Tag="1.0"/>
                                            <ComboBoxItem Content="125%" Tag="1.25"/>
                                            <ComboBoxItem Content="150%" Tag="1.5"/>
                                            <ComboBoxItem Content="175%" Tag="1.75"/>
                                            <ComboBoxItem Content="200%" Tag="2.0"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <Button x:Name="SaveSettingsBtn" Grid.Row="1" Content="Save Configuration" Width="180" Height="36" Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Right" Margin="0,10,15,0" Click="SaveSettingsBtn_Click"/>
                </Grid>

                <!-- 4. EMBEDDED GAME VIEW (game renders inside the launcher window) -->
                <Grid x:Name="GameView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Main content area: game + console -->
                    <Grid x:Name="GameContentGrid" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="GameContentLeftCol" Width="*"/>
                            <ColumnDefinition x:Name="GameContentRightCol" Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition x:Name="GameContentTopRow" Height="*"/>
                            <RowDefinition x:Name="GameContentBottomRow" Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Emulator window is reparented into this area (HwndHost) -->
                        <Border Grid.Row="0" Grid.Column="0" Background="Black">
                            <ContentControl x:Name="EmulatorHostPresenter"/>
                        </Border>

                        <!-- Console panel — changes position based on dock mode -->
                        <Border x:Name="GameConsolePanel" Grid.Row="0" Grid.Column="1" Width="380" Visibility="Collapsed"
                                Background="#E0050508" BorderBrush="#1EFFFFFF" BorderThickness="1,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Header with dock buttons -->
                                <Grid Grid.Row="0" Margin="10,10,10,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Console" FontSize="12" FontWeight="Bold" Foreground="#FFA0A0A5" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button x:Name="ConsoleDockBottomBtn" Width="24" Height="24" FontSize="10" Padding="0" ToolTip="Dock bottom"
                                                Click="ConsoleDockMode_Click" Tag="Bottom" Style="{StaticResource ModernButtonStyle}">⬇</Button>
                                        <Button x:Name="ConsoleDockRightBtn" Width="24" Height="24" FontSize="10" Padding="0" Margin="2,0,0,0" ToolTip="Dock right"
                                                Click="ConsoleDockMode_Click" Tag="Right" Style="{StaticResource ModernButtonStyle}">➡</Button>
                                        <Button x:Name="ConsoleDockLeftBtn" Width="24" Height="24" FontSize="10" Padding="0" Margin="2,0,0,0" ToolTip="Dock left"
                                                Click="ConsoleDockMode_Click" Tag="Left" Style="{StaticResource ModernButtonStyle}">⬅</Button>
                                        <Button x:Name="ConsoleDockFloatBtn" Width="24" Height="24" FontSize="10" Padding="0" Margin="2,0,0,0" ToolTip="Undock (floating)"
                                                Click="ConsoleDockMode_Click" Tag="Float" Style="{StaticResource ModernButtonStyle}">⬜</Button>
                                    </StackPanel>
                                </Grid>
                                <Border x:Name="GameConsoleSlot" Grid.Row="1" Margin="6,0,6,6">
                                    <Border x:Name="ConsoleBorder" Background="#E0050508" BorderBrush="#1EFFFFFF" BorderThickness="1" CornerRadius="6" Padding="8">
                                        <RichTextBox x:Name="ConsoleOutputBox" Background="Transparent" FontFamily="Consolas, Courier New" FontSize="11"
                                                     BorderThickness="0" IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                                     HorizontalScrollBarVisibility="Disabled" IsDocumentEnabled="True">
                                            <RichTextBox.Resources>
                                                <Style TargetType="Paragraph"><Setter Property="Margin" Value="0,0,0,1"/></Style>
                                            </RichTextBox.Resources>
                                        </RichTextBox>
                                    </Border>
                                </Border>
                                <!-- Console action buttons -->
                                <Grid Grid.Row="2" Margin="10,4,10,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Copy" Width="50" Height="22" FontSize="9" Padding="0" Style="{StaticResource ModernButtonStyle}" Click="CopyConsole_Click"/>
                                        <Button Content="Clear" Width="50" Height="22" FontSize="9" Padding="0" Margin="4,0,0,0" Style="{StaticResource ModernButtonStyle}" Click="ClearConsole_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>


                        <!-- BOOT PHASE OVERLAY -->
                        <Grid x:Name="GameBootOverlay" Grid.ColumnSpan="2" Grid.RowSpan="2" Visibility="Collapsed" Background="#D905060A">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
                                <!-- PS5 logo area -->
                                <Border Background="#1A0099FF" CornerRadius="50" Width="80" Height="80"
                                        HorizontalAlignment="Center" Margin="0,0,0,24">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#0099FF" BlurRadius="30" Opacity="0.6" ShadowDepth="0"/>
                                    </Border.Effect>
                                    <TextBlock x:Name="BootSpinnerText" Text="⟳" FontSize="42" Foreground="#0099FF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Phase title -->
                                <TextBlock x:Name="BootPhaseTitle" Text="Initializing..." FontSize="22" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                <!-- Phase detail -->
                                <TextBlock x:Name="BootPhaseDetail" Text="Starting emulator core" FontSize="13"
                                           Foreground="#FFA0A0A5" HorizontalAlignment="Center" TextWrapping="Wrap"
                                           TextAlignment="Center" Margin="0,0,0,28"/>

                                <!-- Progress bar -->
                                <Border CornerRadius="4" Background="#20FFFFFF" Height="6" Margin="0,0,0,24">
                                    <ProgressBar x:Name="BootProgressBar" Minimum="0" Maximum="100" Value="10"
                                                 Background="Transparent" BorderThickness="0" Height="6"
                                                 Foreground="#0099FF"/>
                                </Border>

                                <!-- Game title -->
                                <TextBlock x:Name="BootGameTitle" Text="" FontSize="11" Foreground="#6FA0A0A5"
                                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                                <!-- Cancel button -->
                                <Button x:Name="BootCancelBtn" Content="✕  Cancel Boot" Width="160" Height="36"
                                        Style="{StaticResource ModernButtonStyle}" HorizontalAlignment="Center"
                                        Click="BootCancelBtn_Click" Focusable="True"
                                        Background="#20FF2200" BorderBrush="#40FF2200"/>
                                <TextBlock Text="[◯] Cancel" FontSize="10" Foreground="#4DFFFFFF"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- IN-GAME PAUSE MENU OVERLAY -->
                        <Grid x:Name="PauseMenuOverlay" Grid.ColumnSpan="2" Grid.RowSpan="2" Visibility="Collapsed" Background="#BF000000">
                            <Border Background="#1C1F28" BorderBrush="#400099FF" BorderThickness="1.5"
                                    CornerRadius="16" Width="340" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Padding="0,28,0,28">
                                <Border.Effect>
                                    <DropShadowEffect Color="#0099FF" BlurRadius="40" Opacity="0.4" ShadowDepth="0"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Header -->
                                    <TextBlock Text="P A U S E D" FontSize="11" FontWeight="Bold" Foreground="#6FA0A0A5"
                                               HorizontalAlignment="Center" Margin="0,0,0,4"/>

                                    <TextBlock x:Name="PauseMenuGameTitle" Text="" FontSize="18" FontWeight="ExtraBold"
                                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,24"
                                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="280"/>

                                    <!-- Menu Items -->
                                    <Button x:Name="PauseResumeBtn" Focusable="True" Height="52" Margin="24,0,24,8"
                                            Click="PauseResume_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#200099FF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#400099FF"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="16,0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="Background" Value="#3F0099FF"/>
                                                        <Setter Property="BorderBrush" Value="#0099FF"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A0099FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▶" FontSize="14" Foreground="#0099FF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Text="Resume Game" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <TextBlock Text="  [✕]" FontSize="11" Foreground="#4DFFFFFF" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="PauseConsoleBtn" Focusable="True" Height="48" Margin="24,0,24,8"
                                            Click="PauseConsole_Click" Style="{StaticResource ModernButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⌨" FontSize="13" Foreground="#FFA0A0A5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="Console Logs" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="  [△]" FontSize="11" Foreground="#4DFFFFFF" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="PauseStopBtn" Focusable="True" Height="48" Margin="24,0,24,0"
                                            Click="PauseStop_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#15FF2200"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderBrush" Value="#30FF2200"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="16,0">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="Background" Value="#30FF2200"/>
                                                        <Setter Property="BorderBrush" Value="#FF2200"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#25FF2200"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⏹" FontSize="13" Foreground="#FF6644" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="Stop Game" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="  [◯]" FontSize="11" Foreground="#4DFFFFFF" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <TextBlock Text="[D-Pad ↑↓] Navigate" FontSize="10" Foreground="#30FFFFFF"
                                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Bottom game bar: title + phase status + Console toggle + Stop -->
                    <Border Grid.Row="1" Background="#A0050508" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Height="52">
                        <Grid Margin="20,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="GameBarTitle" Text="Running" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GameBarPhase" Text="" FontSize="11" Foreground="#6FA0A0A5" VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="GameConsoleButton" Content="Console" Width="110" Height="32" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0" Click="GameConsoleButton_Click"/>
                                <Button x:Name="GameKillButton" Content="✕ Force Kill" Width="110" Height="32"
                                        Background="#CC2200" BorderBrush="#FF4400" Foreground="White"
                                        FontWeight="Bold" Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0"
                                        Click="KillButton_Click"/>
                                <Button x:Name="GameStopButton" Content="Stop" Width="80" Height="32" Style="{StaticResource ModernButtonStyle}" Click="StopButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

            </Grid>

            <!-- FOOTER STATUS BAR -->
            <Border Grid.Row="2" Background="#A0050508" BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                        <TextBlock x:Name="FooterGamesCount" Text="Games Loaded: 0" FontSize="11" Foreground="#6FA0A0A5"/>
                        <TextBlock Text="|" Foreground="#25FFFFFF" Margin="12,0,12,0"/>
                        <TextBlock x:Name="FooterStatus" Text="Ready" FontSize="11" Foreground="#0099FF"/>
                        <TextBlock Text="|" Foreground="#25FFFFFF" Margin="12,0,12,0"/>
                        <TextBlock x:Name="FooterGamepadHints" Text="🎮 [L1/R1] Tabs  •  [D-Pad] Move  •  [✕] Select  •  [◯] Back  •  [△] Settings" FontSize="11" FontWeight="SemiBold" Foreground="#0099FF"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="PCSX5 - PlayStation 5 Emulator v1.00" FontSize="10" Foreground="#3FA0A0A5" Margin="0,0,25,0" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- WATCHDOG TOAST — non-blocking "Game may be hung" warning -->
            <Border x:Name="WatchdogToast" Grid.RowSpan="3" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Background="#CC1A0D00" BorderBrush="#60FF6600" BorderThickness="1" CornerRadius="10"
                    Padding="20,12" Margin="0,0,0,80" Visibility="Collapsed" Opacity="0"
                    IsHitTestVisible="True">
                <Border.Effect>
                    <DropShadowEffect Color="#FF6600" BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" Foreground="#FF8800" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Game may be unresponsive" Foreground="#E0FFFFFF" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button x:Name="WatchdogWaitBtn" Content="Wait" Width="70" Height="28" Style="{StaticResource ModernButtonStyle}"
                            FontSize="11" Margin="0,0,6,0" Click="WatchdogWait_Click" Focusable="True"/>
                    <Button x:Name="WatchdogForceStopBtn" Content="Force Stop" Width="90" Height="28"
                            Background="#CC2200" BorderBrush="#FF2200" Foreground="White" FontSize="11" FontWeight="Bold"
                            Focusable="True" Click="WatchdogForceStop_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="  [✕] Wait  [◯] Stop" FontSize="10" Foreground="#4DFFFFFF" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- TOAST NOTIFICATION OVERLAY -->
            <Border x:Name="ToastNotification" Grid.RowSpan="3" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Background="#CC1A1D24" BorderBrush="#3300FF99" BorderThickness="1" CornerRadius="10"
                    Padding="18,10" Margin="0,0,0,50" Visibility="Collapsed" Opacity="0"
                    IsHitTestVisible="False">
                <Border.Effect>
                    <DropShadowEffect Color="#00FF99" BlurRadius="20" Opacity="0.35" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ToastIcon" Text="✓" Foreground="#00FF99" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="ToastMessage" Text="Configuration saved successfully" Foreground="#E0FFFFFF" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>


            <!-- CRASH DIAGNOSTICS OVERLAY DIALOG -->
            <Grid x:Name="CrashDialogOverlay" Visibility="Collapsed" Background="#D905060A" Grid.RowSpan="3">
                <Border Background="#1C1F26" BorderBrush="#CC2200" BorderThickness="1.5" CornerRadius="12" Width="550" Height="420" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="25">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF2200" BlurRadius="25" Opacity="0.4" ShadowDepth="0"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <Border Width="36" Height="36" Background="#20FF2200" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="⚠" Foreground="#FF3300" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CRASH DIAGNOSTICS" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Guest Application Exception Detected" FontSize="11" Foreground="#FFA0A0A5"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Details Area -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
                            <StackPanel>
                                <!-- Summary Row -->
                                <Border Background="#26000000" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Exception Code: " Foreground="#FFA0A0A5" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="CrashExcCodeText" Grid.Row="0" Grid.Column="1" Text="0xC0000005 (Access Violation)" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,5"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Address (RIP): " Foreground="#FFA0A0A5" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock x:Name="CrashRipText" Grid.Row="1" Grid.Column="1" Text="0x800000080" Foreground="#0099FF" FontWeight="Bold" FontSize="12"/>
                                    </Grid>
                                </Border>

                                <!-- Analysis -->
                                <TextBlock Text="AUTOMATED ANALYSIS:" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,6"/>
                                <Border Background="#100099FF" BorderBrush="#200099FF" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                                    <TextBlock x:Name="CrashAnalysisText" TextWrapping="Wrap" Foreground="#FFD0D0D5" FontSize="12" LineHeight="18"
                                               Text="The guest application crashed at address 0x800000080 (Offset: 0x80). This indicates the binary contains encrypted segments or is executing garbage headers. You need to decrypt the executable first."/>
                                </Border>

                                <!-- Raw Logs -->
                                <TextBlock Text="CRASH DUMP EXTRACT:" FontSize="11" FontWeight="Bold" Foreground="#FFA0A0A5" Margin="0,0,0,6"/>
                                <TextBox x:Name="CrashRawText" IsReadOnly="True" Background="#15000000" Foreground="#FFA0A0A5" BorderThickness="0" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10" Padding="8" Height="100" VerticalScrollBarVisibility="Auto" AcceptsReturn="True"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Dismiss" Width="100" Height="32" Style="{StaticResource SecondaryButtonStyle}" Click="DismissCrashDialog_Click" Margin="0,0,10,0"/>
                            <Button Content="Run Boot Analyzer" Width="180" Height="32" Style="{StaticResource ModernButtonStyle}" Click="AnalyzeCrashedGame_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- FIRST-RUN SETUP OVERLAY DIALOG (games folder picker) -->
            <Grid x:Name="FirstRunOverlay" Visibility="Collapsed" Background="#D905060A" Grid.RowSpan="3">
                <Border Background="#1C1F26" BorderBrush="#0099FF" BorderThickness="1.5" CornerRadius="12" Width="560" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect Color="#0099FF" BlurRadius="25" Opacity="0.35" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Welcome to PCSX5" FontSize="22" FontWeight="ExtraBold" Foreground="White" Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#FFA0A0A5" FontSize="13" LineHeight="20" Margin="0,0,0,18"
                                   Text="Before you start, choose the folder where your PS5 game dumps are stored. PCSX5 will scan it to build your game library. You can add or change folders later in System Settings."/>

                        <TextBlock Text="GAMES FOLDER" FontSize="11" FontWeight="Bold" Foreground="#0099FF" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#20FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="6" Padding="10,6">
                                <TextBlock x:Name="FirstRunFolderText" Text="No folder selected" Foreground="White" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            </Border>
                            <Button Grid.Column="1" Content="Browse..." Width="100" Height="32" Margin="10,0,0,0" Style="{StaticResource ModernButtonStyle}" Click="FirstRunBrowse_Click"/>
                        </Grid>

                        <!-- Controller hint -->
                        <TextBlock Text="🎮 [✕] Browse Folder  •  [◯] Skip  •  [△] Continue" FontSize="11" Foreground="#4D0099FF"
                                   HorizontalAlignment="Center" Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="FirstRunSkipBtn" Content="Skip for Now" Width="120" Height="34" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Click="FirstRunSkip_Click" Focusable="True"/>
                            <Button x:Name="FirstRunContinueBtn" Content="Continue" Width="140" Height="34" Style="{StaticResource ModernButtonStyle}" IsEnabled="False" Click="FirstRunContinue_Click" Focusable="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- CONTROLLER FOLDER PICKER OVERLAY
                 Shows before opening the system folder browser dialog. -->

            <Grid x:Name="FolderPickerOverlay" Visibility="Collapsed" Background="#D905060A" Grid.RowSpan="3">
                <Border Background="#1C1F26" BorderBrush="#0099FF" BorderThickness="1.5" CornerRadius="12"
                        Width="480" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32">
                    <Border.Effect>
                        <DropShadowEffect Color="#0099FF" BlurRadius="25" Opacity="0.35" ShadowDepth="0"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="SELECT GAME FOLDER" FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="A folder browser will open. Select the folder containing your PS5 game dumps."
                                   Foreground="#FFA0A0A5" FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,0,0,24" LineHeight="18"/>

                        <TextBlock x:Name="FolderPickerCurrentPath" Text="" FontSize="11" Foreground="#0099FF"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"
                                   MaxHeight="40" TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="🎮 [✕] Open Folder Browser  •  [◯] Cancel" FontSize="11"
                                   Foreground="#4D0099FF" HorizontalAlignment="Center" Margin="0,0,0,18"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="FolderPickerOpenBtn" Content="Open Browser" Width="150" Height="36"
                                    Style="{StaticResource ModernButtonStyle}" Margin="0,0,10,0"
                                    Click="FolderPickerOpen_Click" Focusable="True"/>
                            <Button x:Name="FolderPickerCancelBtn" Content="Cancel" Width="100" Height="36"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="FolderPickerCancel_Click" Focusable="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
